# Ignore everything at root
/*

# Allow important folders
!frontend/
!backend/
!uploads/
!.idea/
!.gitignore

# Allow files inside allowed folders
!frontend/**
!backend/**
!uploads/**
!.idea/**

# Ignore build/dependency folders
frontend/node_modules/
backend/target/
backend/build/
backend/.gradle/
frontend/.next/
frontend/dist/
frontend/.turbo/

# Environment secrets
backend/.env

# OS files
.DS_Store
Thumbs.db

# IDE
.vscode/
*.iml